<?xml version="1.0" encoding="utf-8"?>
<!-- 横屏布局：输入框在左，控制按钮在右 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 终端输出区域 -->
    <WebView
        android:id="@+id/terminal_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/control_area" />

    <!-- 整体控制区域 -->
    <LinearLayout
        android:id="@+id/control_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:padding="1dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 左侧：输入框 -->
        <EditText
            android:id="@+id/et_command"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:hint="$"
            android:inputType="textMultiLine"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textColorHint="#666666"
            android:textSize="12sp"
            android:imeOptions="actionNone"
            android:padding="2dp"
            android:minHeight="28dp" />

        <!-- 右侧：控制按钮区 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 快捷键按钮组 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_ctrl_c"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="Ctrl+C"
                    android:textColor="@android:color/white"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_ctrl_d"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="Ctrl+D"
                    android:textColor="@android:color/white"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_tab"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="Tab"
                    android:textColor="@android:color/white"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_esc"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="Esc"
                    android:textColor="@android:color/white"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_custom1"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="F1"
                    android:textColor="#4CAF50"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_custom2"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="F2"
                    android:textColor="#4CAF50"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_custom3"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="F3"
                    android:textColor="#4CAF50"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#444444" />

            <!-- 方向键 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_left"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="28dp"
                    android:layout_height="26dp"
                    android:text="←"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_up"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="28dp"
                    android:layout_height="26dp"
                    android:text="↑"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_down"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="28dp"
                    android:layout_height="26dp"
                    android:text="↓"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_right"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="28dp"
                    android:layout_height="26dp"
                    android:text="→"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- 分隔线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="#444444" />

            <!-- 输入/回车按钮 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_send"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="输入"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="36dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <Button
                    android:id="@+id/btn_enter"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:text="回车"
                    android:textSize="9sp"
                    android:padding="0dp"
                    android:minWidth="36dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- 隐藏的快捷键栏（保持兼容） -->
    <LinearLayout
        android:id="@+id/quick_keys"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/control_area" />

    <!-- 隐藏的输入区域（保持兼容） -->
    <LinearLayout
        android:id="@+id/input_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>