<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

    <!-- 终端输出区域 -->
    <WebView
        android:id="@+id/terminal_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/control_panel" />

    <!-- 右上角快捷命令按钮 (透明浮动) -->
    <Button
        android:id="@+id/btn_quick_command"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        android:text="快捷命令"
        android:textColor="#4CAF50"
        android:textSize="12sp"
        android:background="#60000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:strokeColor="#4CAF50"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/transparent_keys"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 透明按键区域 (L型布局，往上移动) -->
    <LinearLayout
        android:id="@+id/transparent_keys"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/control_panel">

        <!-- 左侧：上、下 垂直排列 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- 上键 -->
            <Button
                android:id="@+id/btn_up"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="48dp"
                android:text="↑"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:background="#50000000"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#888888"
                app:strokeWidth="2dp" />

            <!-- 下键 -->
            <Button
                android:id="@+id/btn_down"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:text="↓"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:background="#50000000"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#888888"
                app:strokeWidth="2dp" />

        </LinearLayout>

        <!-- 查看键 (与左右键同一行) -->
        <Button
            android:id="@+id/btn_view"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="56dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_gravity="bottom"
            android:text="查看"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:background="#50000000"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#4CAF50"
            app:strokeWidth="2dp" />

        <!-- 左键 -->
        <Button
            android:id="@+id/btn_left"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="56dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_gravity="bottom"
            android:text="←"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:background="#50000000"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#888888"
            app:strokeWidth="2dp" />

        <!-- 右键 -->
        <Button
            android:id="@+id/btn_right"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="56dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_gravity="bottom"
            android:text="→"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:background="#50000000"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#888888"
            app:strokeWidth="2dp" />

    </LinearLayout>

    <!-- 控制面板 (不透明整体) -->
    <LinearLayout
        android:id="@+id/control_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:gravity="center_vertical"
        android:background="#1E1E1E"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 输入框 -->
        <EditText
            android:id="@+id/et_command"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#2D2D2D"
            android:fontFamily="monospace"
            android:hint="点击输入命令..."
            android:inputType="textMultiLine"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textColorHint="#666666"
            android:textSize="14sp"
            android:imeOptions="actionNone"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Esc键 -->
        <Button
            android:id="@+id/btn_esc"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="52dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:text="Esc"
            android:textColor="#FF9800"
            android:textSize="12sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#FF9800"
            app:strokeWidth="1dp" />

        <!-- 自定义快捷键 -->
        <Button
            android:id="@+id/btn_custom"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="60dp"
            android:layout_height="44dp"
            android:layout_marginStart="2dp"
            android:text="自定义"
            android:textColor="#2196F3"
            android:textSize="10sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#2196F3"
            app:strokeWidth="1dp" />

        <!-- 输入按钮 -->
        <Button
            android:id="@+id/btn_send"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="60dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:text="输入"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <!-- 回车按钮 -->
        <Button
            android:id="@+id/btn_enter"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="60dp"
            android:layout_height="44dp"
            android:layout_marginStart="2dp"
            android:text="回车"
            android:textColor="#4CAF50"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#4CAF50"
            app:strokeWidth="2dp" />

    </LinearLayout>

    <!-- 虚拟键盘 -->
    <com.vibecoder.ui.widget.VirtualKeyboardView
        android:id="@+id/virtual_keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/transparent_keys" />

</androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>