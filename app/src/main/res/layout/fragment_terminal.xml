<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 终端输出区域 -->
    <WebView
        android:id="@+id/terminal_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/input_area" />

    <!-- 隐藏的快捷键栏（保持兼容） -->
    <LinearLayout
        android:id="@+id/quick_keys"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/input_area" />

    <!-- 输入区域 -->
    <LinearLayout
        android:id="@+id/input_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="2dp"
        android:background="#1E1E1E"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 左侧：输入框 -->
        <EditText
            android:id="@+id/et_command"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:hint="$"
            android:inputType="textMultiLine"
            android:maxLines="2"
            android:textColor="@android:color/white"
            android:textColorHint="#666666"
            android:textSize="12sp"
            android:imeOptions="actionNone"
            android:padding="2dp" />

        <!-- Esc 按钮 -->
        <Button
            android:id="@+id/btn_esc"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="2dp"
            android:text="Esc"
            android:textColor="@android:color/white"
            android:textSize="9sp"
            android:padding="0dp"
            android:minWidth="36dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#555555"
            app:strokeWidth="1dp" />

        <!-- 自定义快捷键按钮 -->
        <Button
            android:id="@+id/btn_custom1"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="2dp"
            android:text="Ctrl+C"
            android:textColor="#4CAF50"
            android:textSize="9sp"
            android:padding="0dp"
            android:minWidth="44dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#4CAF50"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btn_custom2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="2dp"
            android:text="Ctrl+D"
            android:textColor="#4CAF50"
            android:textSize="9sp"
            android:padding="0dp"
            android:minWidth="44dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#4CAF50"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/btn_custom3"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="2dp"
            android:text="Tab"
            android:textColor="#4CAF50"
            android:textSize="9sp"
            android:padding="0dp"
            android:minWidth="36dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="#4CAF50"
            app:strokeWidth="1dp" />

        <!-- 方向键 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="4dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_up"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="32dp"
                android:layout_height="24dp"
                android:text="↑"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:padding="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#555555"
                app:strokeWidth="1dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_left"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="32dp"
                    android:layout_height="24dp"
                    android:text="←"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#555555"
                    app:strokeWidth="1dp" />

                <Button
                    android:id="@+id/btn_down"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="32dp"
                    android:layout_height="24dp"
                    android:text="↓"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#555555"
                    app:strokeWidth="1dp" />

                <Button
                    android:id="@+id/btn_right"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="32dp"
                    android:layout_height="24dp"
                    android:text="→"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:padding="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeColor="#555555"
                    app:strokeWidth="1dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- 输入/回车按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="2dp">

            <Button
                android:id="@+id/btn_send"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="输入"
                android:textSize="9sp"
                android:padding="0dp"
                android:minWidth="36dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#555555"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/btn_enter"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="回车"
                android:textSize="9sp"
                android:padding="0dp"
                android:minWidth="36dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>